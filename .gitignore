# See http://help.github.com/ignore-files/ for more about ignoring files.

# ==========================================
# Dependencies
# ==========================================
/node_modules
/dist
/tsconfig.tsbuildinfo

# ==========================================
# IDEs and editors
# ==========================================
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
# We commit shared workspace settings but nothing machine-specific.
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# ==========================================
# Next.js build output
# ==========================================
.next
/out

# ==========================================
# Environment variables
# ==========================================
# .env is auto-generated by `npm run initialize:env` from .env.example.
# Never commit real secrets — only commit .env.example with placeholder values.
.env
.env.local
.env*.local

# ==========================================
# OS / system
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/test-results/

# ==========================================
# Prisma — generated / runtime databases
# ==========================================
# `base.sqlite` is the seed database committed to the repo (used as a template).
# `database.sqlite` is copied from base.sqlite by `initialize:database` — local only.
# `test.sqlite` will be generated when the E2E framework lands on setup/playwright.
/prisma/database.sqlite
/prisma/test.sqlite
/prisma/*.db-journal
# ==========================================
# Playwright
# ==========================================
# Playwright HTML report — генерируется после каждого прогона
/playwright-report/
# Артефакты тестов: скриншоты, видео, трейсы
/test-results/
# Allure — сырые результаты и готовый отчёт
/allure-results/
/allure-report/

# Auth state — содержит токены сессии, секрет, никогда не коммитим.
# Папку держим в репо через .gitkeep, но сами JSON-файлы игнорируем.
/tests/auth/*.json
!/tests/auth/.gitkeep