# =============================================================================
# Application (required for `npm run dev` / `npm run build`)
# =============================================================================

# Prisma database connection string — points to the local SQLite file.
# The app uses this DB at runtime.
DATABASE_URL="file:./database.sqlite"

# Secret key for signing JWT tokens. Change this to any random string.
JWT_SECRET="some-super-secret-string"

# =============================================================================
# E2E Tests (required for `npx playwright test`)
# =============================================================================

# Base URL of the running application. Playwright navigates relative to this.
# Default: http://localhost:3000 (same as `npm run dev`)
BASE_URL="http://localhost:3000"

# Separate database for tests — never touches the dev database.
# globalSetup copies base.sqlite → test.sqlite before each run.
TEST_DATABASE_URL="file:./test.sqlite"

# Pre-seeded test user credentials (must match a user in base.sqlite).
# Used by globalSetup to log in via API and save storageState.
TEST_USER_EMAIL="jake@jake.jake"
TEST_USER_PASSWORD="jakejake"
